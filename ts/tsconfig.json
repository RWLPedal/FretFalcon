{
  "compilerOptions": {
    "target": "ES2020",
    "removeComments": false,
    "outDir": "../js/",
    "module": "CommonJS",
    "preserveConstEnums": true,
    "sourceRoot": ".",
    "rootDir": ".",
    "sourceMap": true,
    "alwaysStrict": true,
    "noImplicitThis": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true
  },
  "exclude": ["../tests/**/*"]
}

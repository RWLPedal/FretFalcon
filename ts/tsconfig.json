{
  "compilerOptions": {
    "target": "ES2020",
    "removeComments": false,
    "outDir": "../js/",
    "module": "CommonJS",
    "preserveConstEnums": true,
    "sourceRoot": ".",
    "rootDir": ".",
    "sourceMap": true,
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": ["../tests/**/*"]
}
